# ─────────────────────────────────────────────────────────────────────────────
# .env.example — CTI SSH Key Hunter configuration template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# The .gitignore and .dockerignore both exclude it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ────────────────────────────────────────────────────────────────

# GitHub Personal Access Token (PAT)
# Required scopes: public_repo (read-only) — no write permissions needed.
# Create at: https://github.com/settings/tokens/new
# Recommended: use a fine-grained PAT with "Contents: Read-only" on public repos
GITHUB_TOKEN=ghp_your_token_here

# ── Optional: scan behaviour ────────────────────────────────────────────────

# Key types to search for (space-separated)
# Options: OPENSSH RSA EC DSA PKCS8
# Default: all types
# KEY_TYPES=OPENSSH RSA EC DSA PKCS8

# Maximum results per key-type query (GitHub API ceiling: 1000)
# Lower values = faster scans; higher values = more comprehensive coverage
# MAX_RESULTS=1000

# Seconds to pause between each search result fetch.
# GitHub's secondary rate limit allows ~10 code-search requests/minute.
# Default 6.5s keeps you safely under the limit.
# Increase if you see 403 errors; decrease only with an authenticated token.
RATE_LIMIT_PAUSE=6.5

# ── Optional: output ────────────────────────────────────────────────────────

# Directory where JSON, CSV, and Markdown reports are written.
# In Docker, this should match the volume mount: -v $(pwd)/output:/app/output
OUTPUT_DIR=./output

# ── Optional: logging ───────────────────────────────────────────────────────

# Logging verbosity
# DEBUG   — full request/response detail, useful for development
# INFO    — standard operational output (default)
# WARNING — only problems and rate-limit events
# ERROR   — only failures
LOG_LEVEL=INFO

# ── Optional: health endpoint ────────────────────────────────────────────────

# Set to "true" to start the HTTP /health endpoint on port 8080.
# Always enabled in Docker (via --enable-health flag in CMD).
# ENABLE_HEALTH_ENDPOINT=true
# HEALTH_PORT=8080
